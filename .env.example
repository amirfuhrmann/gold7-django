# Copy to `.env` for local Docker development: cp .env.example .env

# Database
POSTGRES_DB=gold7
POSTGRES_USER=gold7
POSTGRES_PASSWORD=gold7
DATABASE_URL=postgres://gold7:gold7@db:5432/gold7

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.docker

# Bootstrap superuser (created on first boot if no users exist)
DJANGO_SUPERUSER_EMAIL=admin@gold7.local
DJANGO_SUPERUSER_PASSWORD=admin

# Branding
PLATFORM_NAME=Gold7
COMPANY_NAME=Gold7

# Invitations
INVITATION_EXPIRY_DAYS=7

# Email
# Dev: console (prints to logs). Prod: configure an SMTP backend.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@gold7.local
