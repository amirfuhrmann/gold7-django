# Production environment template.
# Copy to `.env` on the server and fill in real secrets (keep `.env.secrets`
# for anything you don't want in this file). Never commit the filled-in copy.

# Database
POSTGRES_DB=gold7
POSTGRES_USER=gold7
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgres://gold7:CHANGE_ME@db:5432/gold7

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=gold7.example.com
CSRF_TRUSTED_ORIGINS=https://gold7.example.com

# Bootstrap superuser (created on first boot if no users exist)
DJANGO_SUPERUSER_EMAIL=admin@gold7.example.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME

# Branding
PLATFORM_NAME=Gold7
COMPANY_NAME=Gold7

# Container image (used by docker-compose.production.yml)
GOLD7_IMAGE=ghcr.io/REPLACE_ME/gold7:latest

# Email
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@gold7.example.com
